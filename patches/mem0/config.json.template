{
    "mem0": {
        "llm": {
            "provider": "openai",
            "config": {
                "model": "gemini-2.5-flash-lite",
                "temperature": 0.1,
                "max_tokens": 2000,
                "api_key": "YOUR_BRIDGE_API_KEY",
                "openai_base_url": "http://host.docker.internal:3458/v1"
            }
        },
        "embedder": {
            "provider": "openai",
            "config": {
                "model": "text-embedding-nomic-embed-text-v1.5@q8_0",
                "api_key": "not-needed",
                "openai_base_url": "http://YOUR_LMSTUDIO_HOST:1234/v1",
                "embedding_dims": 768
            }
        }
    }
}
