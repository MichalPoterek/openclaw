# Gemini Bridge OAuth Configuration
# Copy to .env and fill in values, or set as Environment= in systemd service

# Google OAuth (from Gemini CLI shared credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Bridge API key (used by OpenClaw to authenticate with bridge)
BRIDGE_API_KEY=gemini-oauth-bridge-key-12345

# OAuth credentials file path (shared with Gemini CLI)
CREDS_PATH=/home/mike/.gemini/oauth_creds.json

# Cloud Code Assist API endpoint
CODE_ASSIST_BASE=https://cloudcode-pa.googleapis.com

# Bridge port
PORT=3458

# LM Studio fallback (Qwen 30B on UbuntuLLM)
LMSTUDIO_ENDPOINT=http://172.16.0.118:1234/v1/chat/completions
LMSTUDIO_MODELS_ENDPOINT=http://172.16.0.118:1234/v1/models
LMSTUDIO_API_KEY=your-lmstudio-key
